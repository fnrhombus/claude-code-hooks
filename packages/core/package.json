{
  "name": "@fnrhombus/claude-code-hooks",
  "version": "0.1.1",
  "description": "Strongly-typed TypeScript wrapper for Claude Code hook entrypoints. Write hook scripts as typed functions instead of JSON.parse(process.stdin).",
  "keywords": [
    "claude-code",
    "claude",
    "anthropic",
    "hook",
    "hooks",
    "typescript",
    "types",
    "pretooluse",
    "posttooluse",
    "developer-tools",
    "ai-coding"
  ],
  "author": "fnrhombus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fnrhombus/claude-code-hooks.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/fnrhombus/claude-code-hooks/issues"
  },
  "homepage": "https://github.com/fnrhombus/claude-code-hooks#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types.d.ts",
        "default": "./dist/types.js"
      },
      "require": {
        "types": "./dist/types.d.cts",
        "default": "./dist/types.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
